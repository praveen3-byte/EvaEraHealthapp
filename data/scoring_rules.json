  "core_rules": [
    {
      "id": "R1",
      "description": "Suicidal ideation (PHQ-9 item 9 > 0)",
      "condition": "PHQ9_item9 > 0",
      "action": "psychiatric_alert",
      "severity": "severe",
      "hard_stop": true
    },
    {
      "id": "R2",
      "description": "Confirmed sexual dysfunction: FSFI≤19 AND FSDSR≥11 AND sexually active",
      "condition": "sexuallyActive AND FSFI≤19 AND FSDSR≥11",
      "action": "sexual_therapy_pathway",
      "severity": "moderate"
    },
    {
      "id": "R3",
      "description": "High sexual MenQOL domain — gate psychosexual module",
      "condition": "MENQOL_sexual > 6",
      "action": "activate_psychosexual_module",
      "severity": "mild"
    },
    {
      "id": "R4",
      "description": "Gynaecological red flag (rf1=Yes)",
      "condition": "rf1 === 'Yes'",
      "action": "gynecology_referral",
      "severity": "severe",
      "hard_stop": true
    },
    {
      "id": "R5",
      "description": "Family history breast/ovarian cancer",
      "condition": "fam_breast_cancer OR fam_ovarian_cancer",
      "action": "gynecology_referral",
      "severity": "mild"
    },
    {
      "id": "R6",
      "description": "Family history CVD",
      "condition": "fam_cvd",
      "action": "exercise_program",
      "severity": "mild"
    },
    {
      "id": "R7",
      "description": "Heavy alcohol use (>7 drinks/week)",
      "condition": "alcohol_use === 'Heavy (>7 drinks/week)'",
      "action": "stress_management_program",
      "severity": "moderate"
    },
    {
      "id": "R8",
      "description": "BMI > 30",
      "condition": "BMI > 30",
      "action": "nutrition_guidance",
      "severity": "mild"
    },
    {
      "id": "R9",
      "description": "SSRI + PHQ9≥5 — annotate score attenuation",
      "condition": "med_ssri AND PHQ9 >= 5",
      "action": "psychologist_referral",
      "severity": "mild",
      "note": "PHQ-9 may be attenuated on SSRIs"
    },
    {
      "id": "R10",
      "description": "High sexual domain, no psychosexual module completed",
      "condition": "MENQOL_sexual >= 14 AND NOT psychosexualCompleted",
      "action": "sexual_therapy_pathway",
      "severity": "moderate"
    },
    {
      "id": "RF_GYNE",
      "description": "Any gynaecological red flag (rf1/rf2/rf3)",
      "condition": "rf1=Yes OR rf2=Frequently OR rf3=Yes",
      "action": "gynecology_referral",
      "severity": "severe"
    }
  ],
  "composite_formula": {
    "description": "Weighted sum of normalised domain scores, adjusted for prakriti, stage, comorbidities, wearable data, and lifestyle risk",
    "formula": "composite = round(raw×100 + comorbidityMod×0.45 + vikritMod + wearableMod + medMod)",
    "raw_components": {
      "menopause_N": {
        "weight": 0.3,
        "normaliser": 0.47,
        "description": "MenQOL vasomotor+physical+psychosocial+sexual, stage-adjusted"
      },
      "mental_N": {
        "weight": 0.25,
        "normaliser": 0.22,
        "description": "PHQ9×0.45 + GAD7×0.35 + PSS8×0.20 (when PSS8 assessed)"
      },
      "sleep_N": {
        "weight": 0.15,
        "normaliser": 0.2,
        "description": "ISI/28"
      },
      "sexual_N": {
        "weight": 0.15,
        "normaliser": 0.22,
        "description": "FSFI+FSDSR composite, or stressN proxy if no FSFI"
      },
      "stress_N": {
        "weight": 0.05,
        "description": "PSS8/32"
      },
      "lifestyle_N": {
        "weight": 0.1,
        "description": "Wearable activity+sleep+stress score, default 0.18 if no wearable"
      }
    },
    "modifiers": {
      "comorbidityMod": {
        "weight": 0.45,
        "description": "Sum of comorbidity impact scores × 0.45"
      },
      "vikritMod": {
        "description": "Vikriti imbalance from Prakriti baseline (range -4 to +6)"
      },
      "wearableMod": {
        "description": "Sum of wearable metric abnormality scores"
      },
      "medMod": {
        "description": "Medication/risk modifiers: SSRI+2, antihyp+3, insulin+4, heavy_alc+5, smoking+4, fam_cancer+2, fam_CVD+2"
      }
    },
    "stage_multipliers": {
      "Surgical Menopause": {
        "vasomotor": 1.3,
        "physical": 0.9,
        "psychosocial": 1.1
      },
      "Post-Menopause": {
        "vasomotor": 1.18,
        "physical": 0.92,
        "psychosocial": 1.05
      },
      "Menopause (<1yr)": {
        "vasomotor": 1.1,
        "physical": 0.97,
        "psychosocial": 1.02
      },
      "Perimenopause": {
        "vasomotor": 0.95,
        "physical": 1.02,
        "psychosocial": 0.98
      },
      "Normal Cycle": {
        "vasomotor": 0.85,
        "physical": 1.0,
        "psychosocial": 0.95
      }
    }
  }
}