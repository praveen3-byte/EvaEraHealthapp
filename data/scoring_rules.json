    "Optimal": {
      "min": 0,
      "max": 5,
      "description": "No/minimal burden — clinically healthy",
      "icon": "🌟",
      "action": "wellness_maintenance"
    },
    "Mild": {
      "min": 6,
      "max": 30,
      "description": "Noticeable symptoms — lifestyle management",
      "icon": "🌿",
